cc = gcc
cflags = -Wextra -Wall -pedantic -std=c23 -Iinclude -I/usr/include/lua5.5
libs = -llua5.5 -lm

rule cc
  command = $cc $cflags -c $in -o $out

rule link
  command = $cc $in $libs -o $out

build build/main.o: cc src/main.c
build build/editor.o: cc src/editor.c
build build/gap_buffer.o: cc src/gap_buffer.c
build build/render.o: cc src/render.c

build build/pome: link build/main.o build/editor.o build/gap_buffer.o build/render.o
